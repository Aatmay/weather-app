<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Weather Result</title>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700;800&display=swap');

    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: 'Poppins', sans-serif;
      min-height: 100vh;
      display: flex;
      justify-content: center;
      align-items: flex-start;
      padding: 30px 20px;
      overflow-x: hidden;
      background: linear-gradient(135deg, #0f0c29, #302b63, #24243e);
      position: relative;
    }

    .orb {
      position: fixed;
      border-radius: 50%;
      filter: blur(80px);
      opacity: 0.4;
      z-index: 0;
      animation: orbFloat 8s ease-in-out infinite alternate;
    }

    .orb-1 {
      width: 450px; height: 450px;
      background: #e96c75;
      top: -150px; left: -150px;
    }

    .orb-2 {
      width: 400px; height: 400px;
      background: #a855f7;
      bottom: -100px; right: -100px;
      animation-delay: -4s;
    }

    .orb-3 {
      width: 300px; height: 300px;
      background: #3b82f6;
      top: 40%; left: 35%;
      animation-delay: -2s;
    }

    @keyframes orbFloat {
      0% { transform: translate(0, 0) scale(1); }
      100% { transform: translate(40px, 40px) scale(1.15); }
    }

    .stars {
      position: fixed;
      top: 0; left: 0;
      width: 100%; height: 100%;
      pointer-events: none;
      z-index: 0;
    }

    .star {
      position: absolute;
      background: white;
      border-radius: 50%;
      animation: twinkle ease-in-out infinite alternate;
    }

    @keyframes twinkle {
      0% { opacity: 0.1; }
      100% { opacity: 0.9; }
    }

    .card {
      position: relative;
      z-index: 1;
      background: rgba(255,255,255,0.08);
      backdrop-filter: blur(30px);
      border: 1px solid rgba(255,255,255,0.18);
      border-radius: 30px;
      padding: 40px 35px;
      width: 460px;
      text-align: center;
      box-shadow: 0 30px 100px rgba(0,0,0,0.5),
                  inset 0 1px 0 rgba(255,255,255,0.2);
    }

    .weather-emoji-box {
      display: flex;
      flex-direction: column;
      align-items: center;
      margin-bottom: 15px;
    }

    .big-emoji {
      font-size: 90px;
      line-height: 1;
      animation: floatIcon 4s ease-in-out infinite;
      filter: drop-shadow(0 10px 30px rgba(0,0,0,0.4));
    }

    @keyframes floatIcon {
      0%, 100% { transform: translateY(0px); }
      50% { transform: translateY(-12px); }
    }

    h1 {
      font-size: 32px;
      font-weight: 800;
      color: #ffffff;
      margin-bottom: 4px;
      text-shadow: 0 2px 20px rgba(0,0,0,0.4);
    }

    .condition-text {
      color: rgba(255,255,255,0.6);
      font-size: 14px;
      font-weight: 400;
      margin-bottom: 5px;
      text-transform: capitalize;
    }

    .subtitle {
      color: rgba(255,255,255,0.35);
      font-size: 11px;
      margin-bottom: 20px;
      letter-spacing: 3px;
      text-transform: uppercase;
    }

    .warning-danger {
      background: rgba(239,68,68,0.2);
      border: 1px solid rgba(239,68,68,0.5);
      color: #fca5a5;
      font-size: 13px; font-weight: 600;
      padding: 12px 16px; border-radius: 14px;
      margin-bottom: 15px; text-align: left;
    }
    .warning-warning {
      background: rgba(245,158,11,0.2);
      border: 1px solid rgba(245,158,11,0.5);
      color: #fcd34d;
      font-size: 13px; font-weight: 600;
      padding: 12px 16px; border-radius: 14px;
      margin-bottom: 15px; text-align: left;
    }
    .warning-rain {
      background: rgba(59,130,246,0.2);
      border: 1px solid rgba(59,130,246,0.5);
      color: #93c5fd;
      font-size: 13px; font-weight: 600;
      padding: 12px 16px; border-radius: 14px;
      margin-bottom: 15px; text-align: left;
    }
    .warning-info {
      background: rgba(99,102,241,0.2);
      border: 1px solid rgba(99,102,241,0.5);
      color: #c4b5fd;
      font-size: 13px; font-weight: 600;
      padding: 12px 16px; border-radius: 14px;
      margin-bottom: 15px; text-align: left;
    }

    .rain-yes {
      background: rgba(59,130,246,0.2);
      border: 1px solid rgba(59,130,246,0.5);
      color: #93c5fd;
      font-size: 15px; font-weight: 700;
      padding: 14px 20px; border-radius: 14px;
      margin-bottom: 15px;
    }
    .rain-no {
      background: rgba(34,197,94,0.2);
      border: 1px solid rgba(34,197,94,0.5);
      color: #86efac;
      font-size: 15px; font-weight: 700;
      padding: 14px 20px; border-radius: 14px;
      margin-bottom: 15px;
    }

    .info-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
      margin-bottom: 10px;
    }

    .info-box {
      background: rgba(255,255,255,0.08);
      border-radius: 18px;
      padding: 18px 16px;
      text-align: left;
      border: 1px solid rgba(255,255,255,0.12);
      transition: background 0.3s, transform 0.2s;
    }

    .info-box:hover {
      background: rgba(255,255,255,0.14);
      transform: translateY(-2px);
    }

    .info-label {
      color: rgba(255,255,255,0.4);
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 1px;
      margin-bottom: 8px;
    }

    .info-value {
      color: #ffffff;
      font-size: 22px;
      font-weight: 800;
    }

    .info-unit {
      font-size: 13px;
      font-weight: 400;
      color: rgba(255,255,255,0.45);
    }

    .sun-box {
      background: rgba(255,255,255,0.08);
      border: 1px solid rgba(255,255,255,0.12);
      border-radius: 18px;
      padding: 18px 20px;
      margin-bottom: 10px;
      display: flex;
      justify-content: space-around;
      align-items: center;
    }

    .sun-item { text-align: center; }

    .sun-label {
      color: rgba(255,255,255,0.4);
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 1px;
      margin-bottom: 6px;
    }

    .sun-value {
      color: #ffffff;
      font-size: 18px;
      font-weight: 800;
    }

    .sun-divider {
      width: 1px; height: 45px;
      background: rgba(255,255,255,0.15);
    }

    .prob-bar-container {
      background: rgba(255,255,255,0.08);
      border: 1px solid rgba(255,255,255,0.12);
      border-radius: 18px;
      padding: 18px;
      margin-bottom: 10px;
      text-align: left;
    }

    .prob-bar-label {
      display: flex;
      justify-content: space-between;
      margin-bottom: 10px;
    }

    .prob-bar-text {
      color: rgba(255,255,255,0.4);
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 1px;
    }

    .prob-bar-value {
      color: #ffffff;
      font-size: 14px;
      font-weight: 800;
    }

    .prob-bar {
      height: 10px;
      background: rgba(255,255,255,0.1);
      border-radius: 10px;
      overflow: hidden;
    }

    .prob-bar-fill {
      height: 100%;
      border-radius: 10px;
      background: linear-gradient(90deg, #60a5fa, #a855f7, #e96c75);
    }

    .aqi-container {
      background: rgba(255,255,255,0.08);
      border: 1px solid rgba(255,255,255,0.12);
      border-radius: 18px;
      padding: 18px;
      margin-bottom: 10px;
      text-align: left;
    }

    .aqi-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 12px;
    }

    .aqi-title {
      color: rgba(255,255,255,0.4);
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 1px;
    }

    .aqi-badge-good { background: rgba(34,197,94,0.2); color: #4ade80; border: 1px solid rgba(34,197,94,0.4); font-size: 11px; font-weight: 700; padding: 3px 10px; border-radius: 20px; }
    .aqi-badge-moderate { background: rgba(234,179,8,0.2); color: #facc15; border: 1px solid rgba(234,179,8,0.4); font-size: 11px; font-weight: 700; padding: 3px 10px; border-radius: 20px; }
    .aqi-badge-sensitive { background: rgba(249,115,22,0.2); color: #fb923c; border: 1px solid rgba(249,115,22,0.4); font-size: 11px; font-weight: 700; padding: 3px 10px; border-radius: 20px; }
    .aqi-badge-unhealthy { background: rgba(239,68,68,0.2); color: #f87171; border: 1px solid rgba(239,68,68,0.4); font-size: 11px; font-weight: 700; padding: 3px 10px; border-radius: 20px; }
    .aqi-badge-veryunhealthy { background: rgba(168,85,247,0.2); color: #c084fc; border: 1px solid rgba(168,85,247,0.4); font-size: 11px; font-weight: 700; padding: 3px 10px; border-radius: 20px; }
    .aqi-badge-hazardous { background: rgba(127,29,29,0.4); color: #fca5a5; border: 1px solid rgba(239,68,68,0.6); font-size: 11px; font-weight: 700; padding: 3px 10px; border-radius: 20px; }

    .aqi-number-row {
      display: flex;
      align-items: baseline;
      gap: 10px;
      margin-bottom: 14px;
    }

    .aqi-big-number {
      color: #ffffff;
      font-size: 42px;
      font-weight: 800;
      line-height: 1;
    }

    .aqi-sub {
      color: rgba(255,255,255,0.35);
      font-size: 12px;
      line-height: 1.4;
    }

    .aqi-bar {
      position: relative;
      height: 12px;
      border-radius: 10px;
      background: linear-gradient(90deg,
        #22c55e 0%, #84cc16 20%, #eab308 40%,
        #f97316 60%, #ef4444 80%, #7f1d1d 100%);
      margin-bottom: 8px;
    }

    .aqi-arrow {
      position: absolute;
      top: -7px;
      width: 6px;
      height: 26px;
      background: #ffffff;
      border-radius: 3px;
      transform: translateX(-50%);
      box-shadow: 0 0 12px rgba(255,255,255,1),
                  0 0 25px rgba(255,255,255,0.6);
    }

    .aqi-scale-labels {
      display: flex;
      justify-content: space-between;
    }

    .aqi-scale-text {
      color: rgba(255,255,255,0.3);
      font-size: 9px;
    }

    .section-title {
      color: rgba(255,255,255,0.4);
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 2px;
      margin: 20px 0 12px;
      text-align: left;
    }

    .forecast-grid {
      display: flex;
      gap: 8px;
      justify-content: space-between;
      margin-bottom: 18px;
    }

    .forecast-item {
      background: rgba(255,255,255,0.08);
      border: 1px solid rgba(255,255,255,0.12);
      border-radius: 16px;
      padding: 12px 6px;
      flex: 1;
      text-align: center;
      transition: background 0.3s, transform 0.2s;
    }

    .forecast-item:hover {
      background: rgba(255,255,255,0.14);
      transform: translateY(-3px);
    }

    .forecast-day {
      color: rgba(255,255,255,0.45);
      font-size: 10px;
      text-transform: uppercase;
      letter-spacing: 1px;
      margin-bottom: 5px;
    }

    .forecast-emoji {
      font-size: 28px;
      margin: 4px 0;
    }

    .forecast-temp {
      color: #ffffff;
      font-size: 13px;
      font-weight: 800;
    }

    .forecast-rain {
      color: #60a5fa;
      font-size: 10px;
      margin-top: 3px;
    }

    .error {
      background: rgba(239,68,68,0.15);
      border: 1px solid rgba(239,68,68,0.4);
      color: #f87171;
      font-size: 14px; font-weight: 600;
      padding: 15px 20px; border-radius: 14px;
      margin-bottom: 20px;
    }

    .back-btn {
      display: block;
      margin-top: 15px;
      width: 100%;
      padding: 16px;
      background: linear-gradient(135deg, #e96c75, #a855f7);
      border-radius: 16px;
      color: white;
      font-size: 15px; font-weight: 700;
      font-family: 'Poppins', sans-serif;
      text-decoration: none;
      letter-spacing: 1px;
      transition: opacity 0.3s, transform 0.2s;
      box-shadow: 0 8px 30px rgba(168,85,247,0.4);
    }

    .back-btn:hover { opacity: 0.9; transform: translateY(-2px); }
  </style>
</head>

<body>
  <div class="orb orb-1"></div>
  <div class="orb orb-2"></div>
  <div class="orb orb-3"></div>
  <div class="stars" id="stars"></div>

  <div class="card">

    <% if (error) { %>
      <div class="weather-emoji-box">
        <span class="big-emoji">❌</span>
      </div>
      <h1>Oops!</h1>
      <p class="subtitle">Something went wrong</p>
      <div class="error">❌ <%= error %></div>

    <% } else { %>

      <div class="weather-emoji-box">
        <span class="big-emoji"><%= getEmoji(icon) %></span>
      </div>

      <h1><%= city %></h1>
      <p class="condition-text"><%= description %></p>
      <p class="subtitle">Tomorrow's Forecast</p>

      <% if (warning) { %>
        <div class="warning-<%= warning.type %>"><%= warning.message %></div>
      <% } %>

      <% if (willRain) { %>
        <div class="rain-yes">🌧️ Yes! It will rain tomorrow!</div>
      <% } else { %>
        <div class="rain-no">☀️ No rain tomorrow! Enjoy your day!</div>
      <% } %>

      <div class="info-grid">
        <div class="info-box">
          <div class="info-label">🌡️ Temperature</div>
          <div class="info-value"><%= temperature %><span class="info-unit">°C</span></div>
        </div>
        <div class="info-box">
          <div class="info-label">🤔 Feels Like</div>
          <div class="info-value"><%= feelsLike %><span class="info-unit">°C</span></div>
        </div>
        <div class="info-box">
          <div class="info-label">💧 Humidity</div>
          <div class="info-value"><%= humidity %><span class="info-unit">%</span></div>
        </div>
        <div class="info-box">
          <div class="info-label">💨 Wind Speed</div>
          <div class="info-value"><%= windSpeed %><span class="info-unit">km/h</span></div>
        </div>
      </div>

      <div class="sun-box">
        <div class="sun-item">
          <div class="sun-label">🌅 Sunrise</div>
          <div class="sun-value"><%= sunrise %></div>
        </div>
        <div class="sun-divider"></div>
        <div class="sun-item">
          <div class="sun-label">🌇 Sunset</div>
          <div class="sun-value"><%= sunset %></div>
        </div>
      </div>

      <div class="prob-bar-container">
        <div class="prob-bar-label">
          <span class="prob-bar-text">🌧️ Rain Probability</span>
          <span class="prob-bar-value"><%= rainProb %>%</span>
        </div>
        <div class="prob-bar">
          <div class="prob-bar-fill" style="width: <%= rainProb %>%"></div>
        </div>
      </div>

      <div class="aqi-container">
        <div class="aqi-header">
          <span class="aqi-title">🌿 Current Air Quality Index</span>
          <span class="aqi-badge-<%= aqiCategory.color %>"><%= aqiCategory.label %></span>
        </div>
        <div class="aqi-number-row">
          <div class="aqi-big-number"><%= aqiValue %></div>
          <div class="aqi-sub">US AQI<br/>PM2.5 based</div>
        </div>
        <div class="aqi-bar">
          <div class="aqi-arrow" style="left: <%= aqiArrowPos %>%"></div>
        </div>
        <div class="aqi-scale-labels">
          <span class="aqi-scale-text">0</span>
          <span class="aqi-scale-text">50</span>
          <span class="aqi-scale-text">100</span>
          <span class="aqi-scale-text">150</span>
          <span class="aqi-scale-text">200</span>
          <span class="aqi-scale-text">300</span>
          <span class="aqi-scale-text">500</span>
        </div>
      </div>

      <p class="section-title">📅 5 Day Forecast</p>
      <div class="forecast-grid">
        <% fiveDay.forEach(day => { %>
          <div class="forecast-item">
            <div class="forecast-day"><%= day.date.split(",")[0] %></div>
            <div class="forecast-emoji"><%= getEmoji(day.icon) %></div>
            <div class="forecast-temp"><%= day.temp %>°C</div>
            <div class="forecast-rain">💧<%= day.rainProb %>%</div>
          </div>
        <% }) %>
      </div>

    <% } %>

    <a href="/" class="back-btn">← Check Another City</a>
  </div>

  <script>
    const starsContainer = document.getElementById('stars');
    for (let i = 0; i < 120; i++) {
      const star = document.createElement('div');
      star.classList.add('star');
      const size = Math.random() * 2.5 + 0.5;
      star.style.width = size + 'px';
      star.style.height = size + 'px';
      star.style.top = Math.random() * 100 + '%';
      star.style.left = Math.random() * 100 + '%';
      star.style.animationDuration = (Math.random() * 3 + 2) + 's';
      star.style.animationDelay = (Math.random() * 3) + 's';
      starsContainer.appendChild(star);
    }
  </script>
</body>
</html>