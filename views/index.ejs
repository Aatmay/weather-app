<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Rain Checker</title>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700;800&display=swap');

    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: 'Poppins', sans-serif;
      min-height: 100vh;
      display: flex;
      justify-content: center;
      align-items: center;
      overflow: hidden;
      background: linear-gradient(180deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
    }

    /* Stars */
    .stars {
      position: fixed;
      top: 0; left: 0;
      width: 100%; height: 100%;
      pointer-events: none;
      z-index: 0;
    }

    .star {
      position: absolute;
      background: white;
      border-radius: 50%;
      animation: twinkle 3s infinite alternate;
    }

    @keyframes twinkle {
      0% { opacity: 0.2; transform: scale(1); }
      100% { opacity: 1; transform: scale(1.3); }
    }

    /* Clouds */
    .cloud {
      position: fixed;
      background: rgba(255,255,255,0.08);
      border-radius: 50px;
      animation: floatCloud 20s linear infinite;
      z-index: 0;
    }

    .cloud::before, .cloud::after {
      content: '';
      position: absolute;
      background: rgba(255,255,255,0.08);
      border-radius: 50%;
    }

    .cloud-1 { width: 200px; height: 60px; top: 15%; animation-duration: 25s; }
    .cloud-2 { width: 150px; height: 45px; top: 35%; animation-duration: 18s; animation-delay: -8s; }
    .cloud-3 { width: 180px; height: 55px; top: 60%; animation-duration: 22s; animation-delay: -15s; }

    @keyframes floatCloud {
      0% { left: -300px; }
      100% { left: 110%; }
    }

    /* Moon */
    .moon {
      position: fixed;
      top: 40px;
      right: 80px;
      width: 70px;
      height: 70px;
      background: radial-gradient(circle at 35% 35%, #fffde7, #ffd54f);
      border-radius: 50%;
      box-shadow: 0 0 30px rgba(255,213,79,0.4), 0 0 60px rgba(255,213,79,0.2);
      z-index: 0;
    }

    /* Card */
    .card {
      position: relative;
      z-index: 1;
      background: rgba(255,255,255,0.07);
      backdrop-filter: blur(20px);
      border: 1px solid rgba(255,255,255,0.15);
      border-radius: 28px;
      padding: 45px 40px;
      width: 420px;
      text-align: center;
      box-shadow: 0 25px 80px rgba(0,0,0,0.5);
    }

    .weather-emoji {
      font-size: 70px;
      margin-bottom: 15px;
      display: block;
      animation: float 4s ease-in-out infinite;
      filter: drop-shadow(0 10px 20px rgba(0,0,0,0.3));
    }

    @keyframes float {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-12px); }
    }

    h1 {
      font-size: 28px;
      font-weight: 800;
      color: #ffffff;
      margin-bottom: 6px;
      text-shadow: 0 2px 10px rgba(0,0,0,0.3);
    }

    .subtitle {
      color: rgba(255,255,255,0.45);
      font-size: 13px;
      margin-bottom: 35px;
      letter-spacing: 2px;
      text-transform: uppercase;
    }

    .input-box {
      background: rgba(255,255,255,0.08);
      border: 1px solid rgba(255,255,255,0.12);
      border-radius: 16px;
      padding: 16px 20px;
      margin-bottom: 15px;
      display: flex;
      align-items: center;
      gap: 15px;
      text-align: left;
      transition: border 0.3s;
    }

    .input-box:focus-within {
      border: 1px solid rgba(168,85,247,0.5);
      background: rgba(255,255,255,0.1);
    }

    .input-icon { font-size: 22px; }

    .input-inner { flex: 1; }

    .input-label {
      color: rgba(255,255,255,0.35);
      font-size: 10px;
      text-transform: uppercase;
      letter-spacing: 1.5px;
      margin-bottom: 5px;
    }

    input {
      width: 100%;
      background: transparent;
      border: none;
      outline: none;
      color: #ffffff;
      font-size: 16px;
      font-weight: 600;
      font-family: 'Poppins', sans-serif;
    }

    input::placeholder {
      color: rgba(255,255,255,0.2);
      font-weight: 300;
    }

    button {
      margin-top: 10px;
      width: 100%;
      padding: 16px;
      background: linear-gradient(135deg, #e96c75, #a855f7);
      border: none;
      border-radius: 16px;
      color: white;
      font-size: 16px;
      font-weight: 700;
      font-family: 'Poppins', sans-serif;
      cursor: pointer;
      letter-spacing: 1px;
      transition: opacity 0.3s, transform 0.2s;
      box-shadow: 0 8px 25px rgba(168,85,247,0.4);
    }

    button:hover {
      opacity: 0.9;
      transform: translateY(-2px);
    }

    button:active { transform: translateY(0); }

    .features {
      display: flex;
      justify-content: center;
      gap: 20px;
      margin-top: 25px;
    }

    .feature-item {
      color: rgba(255,255,255,0.3);
      font-size: 11px;
      display: flex;
      align-items: center;
      gap: 5px;
    }
  </style>
</head>
<body>

  <!-- Background Elements -->
  <div class="moon"></div>
  <div class="cloud cloud-1"></div>
  <div class="cloud cloud-2"></div>
  <div class="cloud cloud-3"></div>

  <!-- Stars -->
  <div class="stars" id="stars"></div>

  <div class="card">
    <span class="weather-emoji">🌦️</span>
    <h1>Will It Rain Tomorrow?</h1>
    <p class="subtitle">Your Personal Weather Assistant</p>

    <form action="/weather" method="POST">
      <div class="input-box">
        <span class="input-icon">🏙️</span>
        <div class="input-inner">
          <div class="input-label">Enter City Name</div>
          <input type="text" name="city" placeholder="e.g. Mumbai, London, New York" required />
        </div>
      </div>
      <button type="submit">🔍 Check Weather →</button>
    </form>

    <div class="features">
      <div class="feature-item">🌡️ Temperature</div>
      <div class="feature-item">💧 Humidity</div>
      <div class="feature-item">📅 5-Day</div>
      <div class="feature-item">🌿 AQI</div>
    </div>
  </div>

  <script>
    // Generate stars
    const starsContainer = document.getElementById('stars');
    for (let i = 0; i < 100; i++) {
      const star = document.createElement('div');
      star.classList.add('star');
      star.style.width = Math.random() * 3 + 'px';
      star.style.height = star.style.width;
      star.style.top = Math.random() * 100 + '%';
      star.style.left = Math.random() * 100 + '%';
      star.style.animationDelay = Math.random() * 3 + 's';
      star.style.animationDuration = (Math.random() * 3 + 2) + 's';
      starsContainer.appendChild(star);
    }
  </script>
</body>
</html>